{
  "name": "djcytools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --no-warnings=ExperimentalWarning ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "node --no-warnings=ExperimentalWarning ./node_modules/vite/bin/vite.js build",
    "test": "node --no-warnings=ExperimentalWarning --test",
    "test:e2e": "playwright test",
    "check": "npm run test && npm run build",
    "preview": "node --no-warnings=ExperimentalWarning ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "start": "node --no-warnings=ExperimentalWarning server.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
